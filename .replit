modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3001
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001

[[ports]]
localPort = 5002

[[ports]]
localPort = 5003

[[ports]]
localPort = 5004
externalPort = 3001

[[ports]]
localPort = 5005
externalPort = 3003

[[ports]]
localPort = 5006
externalPort = 4200

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
build = ["npm", "run", "build"]
deploymentTarget = "static"
publicDir = "dist"
